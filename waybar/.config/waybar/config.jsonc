{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "idle_inhibitor",
        "power-profiles-daemon",
        "backlight",
        "network",
        "pulseaudio",
        "cpu",
        "memory",
        "temperature",
        "battery"
    ],
    "include": [
        "~/.config/waybar/modules.jsonc"
    ]
}
